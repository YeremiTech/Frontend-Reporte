{
  "name": "comisiones-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "start:prod": "ng serve --configuration production",
    "lighthouse": "npm run preview",
    "build": "ng build",
    "preview": "ng build && npx --yes http-server dist/comisiones-frontend/browser -p 4200 -c-1",
    "build:stats": "ng build --stats-json",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/router": "^19.2.0",
    "apexcharts": "^3.54.1",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "ng-apexcharts": "^1.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.26",
    "@angular/cli": "^19.2.26",
    "@angular/compiler-cli": "^19.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.2"
  }
